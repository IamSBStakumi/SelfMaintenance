# envファイルの例
# このファイルに倣って環境変数を指定する
# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:00000
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxx

# GA4（公開キーのため NEXT_PUBLIC）
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXXX

# 認証用のクライアントキーなど
GOOGLE_CLIENT_ID=0000000000000-XXXXXXXXXXXXXXXXXX.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXX
GOOGLE_REDIRECT_URI=http://localhost:55321/auth/v1/callback